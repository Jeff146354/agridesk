DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=agridesk
SECRET_KEY=change-this-secret-key-in-production
DB_INIT_ON_STARTUP=true
DB_INIT_FAIL_FAST=false

# Public URL used for QR codes embedded in PDFs (must be accessible from mobile devices)
BASE_URL=https://drive.hq.idenx.id

# Storage — set to False to use local filesystem (recommended for mini-pc)
USE_S3=false

# Upload directory inside the container (mounted to host disk via Docker volume)
UPLOAD_DIR=uploads